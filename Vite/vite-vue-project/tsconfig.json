{
    "compilerOptions": {
        "target": "es2015",
        "module": "esnext",
        "strict": true,
        "isolatedModules": false,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "moduleResolution": "Bundler",
        "esModuleInterop": true, // 允许导入CommonJS模块,
        "useDefineForClassFields": true, // 启用ES2022的类字段定义
        "skipLibCheck": true, // 跳过node_modules的类型检查
        "types": [
            "vite/client",
            "vue",
            "node"
        ],
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "App.vue",
        "vite.config.ts"
    ],
    "exclude": [
        "dist"
    ]
}