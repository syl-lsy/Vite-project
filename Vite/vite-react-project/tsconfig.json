{
    "compilerOptions": {
        "target": "es2015",
        "module": "esnext",
        "strict": true,
        "isolatedModules": false,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true, // 允许导入CommonJS模块
        "jsx": "preserve",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.tsx",
        // "src/**/*.vue",
        "src/vite-env.d.ts",
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}